---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import Slider from '../components/Slider.astro';
import { getCollection } from 'astro:content';
import { SITE_TITLE, SITE_DESCRIPTION } from '../consts';

const allPosts = await getCollection('blog');
const latestPosts = allPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 10);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
		<style>
			body {
				overflow-x: hidden;
			}

			.section-title {
				text-align: center;
				margin-top: 4rem;
				font-size: 2.5rem;
				color: var(--accent-purple);
			}

			.cta-container {
				display: flex;
				justify-content: center;
				margin: 4rem 0 6rem 0;
			}

			.cta-button {
				font-family: var(--font-title);
				font-size: 1.8rem;
				padding: 1rem 2.5rem;
				background: transparent;
				border: 0.5px solid var(--accent-orange);
				color: var(--accent-orange);
				text-decoration: none;
				border-radius: 0;
				transition: all 0.4s ease;
				box-shadow: 0 0 10px rgba(255, 117, 24, 0.2);
			}

			.cta-button:hover {
				background: var(--accent-orange);
				color: var(--bg-navy);
				transform: scale(1.05);
				box-shadow: 0 0 30px var(--accent-orange);
			}

			main {
				width: 100%;
				max-width: 1200px;
				margin: auto;
				padding: 0;
			}

			.mist {
				position: fixed;
				top: 0;
				left: 0;
				width: 100%;
				height: 100%;
				pointer-events: none;
				background: url('https://www.transparenttextures.com/patterns/asfalt-dark.png');
				opacity: 0.05;
				z-index: 10;
			}
		</style>
	</head>
	<body>
		<div class="mist"></div>
		<Header />
		<main>
			<section id="stories">
				<h2 class="section-title">nuestras historias</h2>
				<h4 style="font-family: 'Times New Roman', Times, serif, Courier, monospace; text-align: center;">
				“Aquí viven las historias de aquellos que creyeron que su imaginación no tenía límites.” <br> — Tim Burton	
				</h4>
				<Slider posts={latestPosts} />
			</section>

			<section class="cta-container">
				<a href="/blog" class="cta-button">Ver todas las historias</a>
			</section>
		</main>
		<Footer />
	</body>
</html>
